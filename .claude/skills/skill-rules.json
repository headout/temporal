    "create-handoff": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "critical",
      "description": "Create handoff document to preserve work across sessions",
      "promptTriggers": {
        "keywords": [
          "handoff",
          "create handoff",
          "preserve work",
          "save progress",
          "context high",
          "before clear"
        ],
        "intentPatterns": [
          "(create|make|write).*?handoff",
          "(preserve|save).*?(work|progress|context)",
          "before.*(clear|compaction)"
        ]
      }
    },
    "resume-handoff": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "critical",
      "description": "Resume work from handoff document",
      "promptTriggers": {
        "keywords": [
          "resume handoff",
          "resume from handoff",
          "continue from handoff",
          "pick up from handoff",
          "latest handoff",
          "load the handoff"
        ],
        "intentPatterns": [
          "(resume|continue|pick up).*?handoff",
          "latest.*?handoff",
          "(resume|continue|start).*?from.*?(the )?handoff"
        ]
      }
    },
